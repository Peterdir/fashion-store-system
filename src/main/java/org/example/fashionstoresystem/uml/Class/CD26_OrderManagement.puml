@startuml
title Class Diagram: Order Management (UC26)

' Controller
class OrderManagementController {
    - orderManagementService : OrderManagementService
    + getAllOrders() : String
    + getOrderDetails(id: Long) : String
    + updateOrderStatus(id: Long, newStatus: OrderStatus) : MessageResponseDTO
}

' Service
interface OrderManagementService <<interface>> {
    + getAllOrders() : List<Order>
    + getOrderDetails(id: Long) : Order
    + updateOrderStatus(id: Long, newStatus: OrderStatus) : void
}

class OrderManagementServiceImpl {
    - orderRepository : OrderRepository
    - historyRepository : OrderHistoryRepository
    + getAllOrders() : List<Order>
    + getOrderDetails(id: Long) : Order
    + updateOrderStatus(id: Long, newStatus: OrderStatus) : void
    - checkStatusTransition(currentStatus: OrderStatus, newStatus: OrderStatus) : void
}

' Repository
interface OrderRepository <<interface>> {
    + findAll() : List<Order>
    + findById(id: Long) : Order
    + save(order: Order) : Order
}

interface OrderHistoryRepository <<interface>> {
    + save(history: OrderHistory) : OrderHistory
}

' DTO

class MessageResponseDTO {
    - message : String
}

' Entity

class Order {
    - id : Long
    - totalAmount : Double
    - status : OrderStatus
    - orderDate : Date
    - cancellationReason : String
    - refundStatus : RefundStatus
}

class OrderHistory {
    - id : Long
    - order : Order
    - previousStatus : OrderStatus
    - newStatus : OrderStatus
    - changeDate : Date
}

' Relationships

' Implementation
OrderManagementServiceImpl ..|> OrderManagementService

' Dependency Injection
OrderManagementController --> OrderManagementService : - orderManagementService
OrderManagementServiceImpl --> OrderRepository : - orderRepository
OrderManagementServiceImpl --> OrderHistoryRepository : - historyRepository

' Object Usage
OrderManagementController ..> Order : <<uses>>
OrderManagementController ..> MessageResponseDTO : <<returns>>
OrderManagementServiceImpl ..> Order : <<uses>>
OrderRepository ..> Order : <<manages>>

OrderManagementServiceImpl ..> OrderHistory : <<creates>>
OrderHistoryRepository ..> OrderHistory : <<manages>>

@enduml