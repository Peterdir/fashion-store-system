@startuml
title Class Diagram : Payment (UC12)

' Controller
class PaymentController {
    - paymentService : PaymentService
    + showPaymentPage(orderId: Long) : String
    + processPayment(orderId: Long, method: String) : PaymentResponseDTO
}

' Service
interface PaymentService <<interface>> {
    + getOrderDetails(orderId: Long) : Order
    + processPayment(orderId: Long, method: String) : PaymentResponseDTO
}

class PaymentServiceImpl {
    - orderRepository : OrderRepository
    - paymentGateway : PaymentGateway
    + getOrderDetails(orderId: Long) : Order
    + processPayment(orderId: Long, method: String) : PaymentResponseDTO
}

' External Gateway Service
interface PaymentGateway <<interface>> {
    + requestPayment(amount: Double, orderInfo: String) : PaymentResponseDTO
}

' Repository
interface OrderRepository <<interface>> {
    + findById(orderId: Long) : Order
    + save(order: Order) : Order
}

' DTO

class PaymentResponseDTO {
    - status : String
    - transactionId : String
    - message : String
}

' Entity

class Order {
    - id : Long
    - totalAmount : Double
    - status : OrderStatus
    - paymentMethod : String
    - orderDate : Date
    - cancellationReason : String
    - refundStatus : String
}

' Relationships

' Class implement Interface
PaymentServiceImpl ..|> PaymentService

' Dependency Injection
PaymentController --> PaymentService : - paymentService
PaymentServiceImpl --> OrderRepository : - orderRepository
PaymentServiceImpl --> PaymentGateway : - paymentGateway

' Object Usage
PaymentController ..> Order : <<uses>>
PaymentController ..> PaymentResponseDTO : <<returns>>
PaymentServiceImpl ..> Order : <<uses>>
OrderRepository ..> Order : <<manages>>

PaymentGateway ..> PaymentResponseDTO : <<creates>>
PaymentServiceImpl ..> PaymentResponseDTO : <<uses>>

@enduml