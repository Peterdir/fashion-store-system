@startuml
title Class Diagram: Submit Return Request (UC22)

' Controller
class ReturnRequestController {
    - returnRequestService : ReturnRequestService
    + showOrderList(customerId: Long) : String
    + showReturnSelection(orderId: Long) : String
    + prepareReturnForm(orderId: Long, itemIds: List<Long>) : String
    + submitReturnRequest(returnDto: ReturnRequestDTO) : String
}

' Service
interface ReturnRequestService <<interface>> {
    + getOrdersByCustomer(customerId: Long) : List<Order>
    + getOrderForReturn(orderId: Long) : Order
    + validateReturnEligibility(orderId: Long, itemIds: List<Long>) : List<OrderItem>
    + submitReturnRequest(returnDto: ReturnRequestDTO, images: List<String>) : ReturnRequest
}

class ReturnRequestServiceImpl {
    - orderRepository : OrderRepository
    - returnRepository : ReturnRequestRepository
    + getOrdersByCustomer(customerId: Long) : List<Order>
    + getOrderForReturn(orderId: Long) : Order
    + validateReturnEligibility(orderId: Long, itemIds: List<Long>) : List<OrderItem>
    + submitReturnRequest(returnDto: ReturnRequestDTO, images: List<String>) : ReturnRequest
    - createReturnRequest(dto: ReturnRequestDTO) : ReturnRequest
}

' Repository
interface OrderRepository <<interface>> {
    + findByCustomerId(customerId: Long) : List<Order>
    + findById(orderId: Long) : Order
}

interface ReturnRequestRepository <<interface>> {
    + existsByOrderItemIdIn(itemIds: List<Long>) : Boolean
    + save(returnRequest: ReturnRequest) : ReturnRequest
}

' Entity & DTO
class ReturnRequestDTO {
    - orderId : Long
    - itemIds : List<Long>
    - reason : String
    - description : String
}

class ReturnRequest {
    - id : Long
    - status : String
    - reason : String
    - description : String
    - requestDate : Date
    + setStatus(status: String) : void
}

class Order {
    - id : Long
    - status : String
}

class OrderItem {
    - id : Long
}

' Relationships

' Implementation
ReturnRequestServiceImpl ..|> ReturnRequestService

' Dependency Injection
ReturnRequestController --> ReturnRequestService : - returnRequestService
ReturnRequestServiceImpl --> OrderRepository : - orderRepository
ReturnRequestServiceImpl --> ReturnRequestRepository : - returnRepository

' Object Usage
ReturnRequestController ..> ReturnRequestDTO : <<uses>>
ReturnRequestServiceImpl ..> ReturnRequestDTO : <<uses>>

ReturnRequestServiceImpl ..> ReturnRequest : <<creates>>
ReturnRequestRepository ..> ReturnRequest : <<manages>>

ReturnRequestServiceImpl ..> Order : <<uses>>
OrderRepository ..> Order : <<manages>>

ReturnRequestServiceImpl ..> OrderItem : <<uses>>

@enduml