@startuml
title Activity Diagram (Swimlane) - Payment (UC12) - MoMo Integration

|Client (UI)|
start
:Nhấn Thanh toán (Thử lại) hoặc Chọn Đặt mua thông qua Ví MoMo;

|System (Service)|
:Tạo chữ ký bảo mật (Signature);
:Tạo URL thanh toán MoMo (ReturnUrl & NotifyUrl);

|Client (UI)|
:Chuyển hướng đến Cổng thanh toán MoMo;

|Payment Gateway (MoMo)|
:Hiển thị giao diện quét mã / đăng nhập;
:Khách hàng thực hiện thanh toán;
:Xử lý giao dịch;

fork
    |Payment Gateway (MoMo)|
    :Gửi IPN (Webhook) về Hệ thống;
    |System (Service)|
    :Nhận payload từ NotifyUrl;
    :Xác thực chữ ký (Signature);
    if (Chữ ký hợp lệ?) then (Có)
        |Database (MySQL)|
        :Cập nhật trạng thái OrderItem (PAID / PAYMENT_FAILED);
        :Lưu lịch sử giao dịch (OrderHistory);
    else (Không)
        |System (Service)|
        :Bỏ qua yêu cầu;
    endif
fork again
    |Payment Gateway (MoMo)|
    :Trả trình duyệt về ReturnUrl;
    |System (Service)|
    :Nhận tham số từ ReturnUrl;
    :Xác thực chữ ký tham số trả về;
    :Kiểm tra mã lỗi (ResultCode);
    if (Giao dịch thành công?) then (Có)
        |Database (MySQL)|
        :Đảm bảo cập nhật trạng thái PAID (dự phòng IPN trễ);
        |Client (UI)|
        :Hiển thị "Thanh toán thành công";
    else (Không)
        |Database (MySQL)|
        :Đảm bảo cập nhật trạng thái PAYMENT_FAILED;
        |Client (UI)|
        :Hiển thị "Thanh toán thất bại";
    endif
end fork

stop
@enduml