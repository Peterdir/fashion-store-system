@startuml
title Activity Diagram (Swimlane) - Submit Return Request (UC22)

|Client (UI)|
start
:Truy cập mục "Đơn hàng của tôi";
:Chọn đơn hàng "Đã giao thành công";
:Hệ thống Call API lấy chi tiết đơn hàng;
:Chọn các sản phẩm & nhấn "Yêu cầu hoàn trả";
:Nhập lý do, mô tả & hình ảnh;
:Xác nhận gửi thông tin (Call API SubmitReturnRequest);

|System (Service)|
:Truy vấn OrderRepository kiểm tra tồn tại;
if (Khách hàng sở hữu đơn hàng?) then (Không)
    |Client (UI)|
    :Thông báo lỗi bảo mật / không hợp lệ;
    stop
else (Có)
    |System (Service)|
    :Kiểm tra từng sản phẩm dựa trên ItemIds;
    if (Đã có yêu cầu hoàn trả cho sản phẩm chưa?) then (Có)
        |Client (UI)|
        :Thông báo sản phẩm đã được gửi yêu cầu trước đó;
        stop
    else (Không)
        |Database (MySQL)|
        :Lưu thông tin ReturnRequest (status: PENDING_APPROVAL);
        :Lưu image_url vào bảng return_request_images;
        :Cập nhật các OrderItem liên quan (gắn return_request_id, refund_status: RETURN_REQUESTED);

        |System (Service)|
        if (Lỗi lưu trữ (Exception)?) then (Có)
            :Rollback Transaction;
            |Client (UI)|
            :Thông báo lỗi hệ thống;
            stop
        else (Thành công)
            |Client (UI)|
            :Hiển thị "Gửi yêu cầu thành công";
            :Cập nhật UI trạng thái sản phẩm;
            stop
        endif
    endif
endif

@enduml
