@startuml
title Activity Diagram (Swimlane) - Submit Return Request (UC22)

|Client (UI)|
start
:Truy cập mục "Đơn hàng của tôi";
:Chọn đơn hàng "Đã giao thành công";
:Chọn sản phẩm & nhấn "Yêu cầu hoàn trả";

|System (Service)|
''' Bước 6: Kiểm tra các điều kiện '''
if (Sở hữu & Trạng thái hợp lệ?) then (Không)
    |Client (UI)|
    :Thông báo lỗi đơn hàng;
    stop
else (Có)
    |System (Service)|
    if (Đúng chính sách hoàn trả?) then (Không)
        |Client (UI)|
        :Thông báo không đủ điều kiện;
        stop
    else (Có)
        |System (Service)|
        if (Đã có yêu cầu đang xử lý?) then (Có)
            |Client (UI)|
            :Thông báo yêu cầu đã tồn tại;
            stop
        else (Không)
            |Client (UI)|
            :Hiển thị Biểu mẫu hoàn trả;
            :Nhập lý do, mô tả & hình ảnh;
            :Xác nhận gửi yêu cầu;

            |System (Service)|
            :Chuẩn bị dữ liệu yêu cầu;

            |Database (MySQL)|
            :Lưu thông tin yêu cầu (ReturnRequests);
            :Lưu danh sách sản phẩm hoàn (ReturnRequestItems);
            :Cập nhật trạng thái: Chờ duyệt;

            |System (Service)|
            if (Lỗi khi lưu dữ liệu?) then (Có)
                |Client (UI)|
                :Thông báo lỗi hệ thống;
            else (Thành công)
                |Client (UI)|
                :Hiển thị "Gửi yêu cầu thành công";
            endif
        endif
    endif
endif

stop
@enduml
