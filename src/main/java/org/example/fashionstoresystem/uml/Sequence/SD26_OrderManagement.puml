@startuml
title Sequence Diagram: Order Management (UC26)

autonumber
actor "Store Admin" as Owner
participant "Admin Frontend\n(JS / Browser)" as View
participant "AdminOrderController\n(API Controller)" as Controller
participant "OrderManagementService\n(Service)" as Service
participant "OrderRepository" as OrderRepo
participant "OrderItemRepository" as ItemRepo
participant "OrderHistoryRepository" as HistoryRepo
database "MySQL\n(Database)" as DB

== 1. View Order List ==

Owner -> View : Access "Order Management"
View -> Controller : getAllOrders(status, dates, pageable)
note right: GET /api/admin/orders
Controller -> Service : getAllOrders()
Service -> OrderRepo : findFiltered(...)
OrderRepo -> DB : SELECT * FROM orders
DB --> OrderRepo : Page<Order>
OrderRepo --> Service : Page<Order>
Service --> Controller : Page<OrderSummaryResponseDTO>
Controller --> View : 200 OK (Page<DTO>)
View --> Owner : Render orders table

== 2. View Order Details ==

Owner -> View : Click on specific Order
View -> Controller : getOrderDetail(orderId)
note right: GET /api/admin/orders/{orderId}
Controller -> Service : getOrderDetail(orderId)
Service -> OrderRepo : findById(orderId)
OrderRepo --> Service : Order Entity
Service --> Controller : OrderDetailResponseDTO
Controller --> View : 200 OK (OrderDetailResponseDTO)
View --> Owner : Display Order info & Items

== 3. Update Order Item Status ==

Owner -> View : Select new status for Item & Click "Update"
View -> Controller : updateOrderItemStatus(itemId, status)
note right: PATCH /api/admin/orders/items/{itemId}/status
Controller -> Service : updateOrderItemStatus(itemId, status)

group Validate and Update Status
    Service -> ItemRepo : findById(itemId)
    ItemRepo --> Service : OrderItem Entity
    
    Service -> Service : checkStatusTransition(current, new)
    
    alt Status Transition Invalid
        Service --> Controller : throw RuntimeException
        Controller --> View : 400 Bad Request
        View --> Owner : Display Error Notification
    else Status Valid
        Service -> ItemRepo : save(updated OrderItem)
        ItemRepo -> DB : UPDATE order_items SET status = ...
        
        == Record History ==
        Service -> HistoryRepo : save(new OrderHistory)
        HistoryRepo -> DB : INSERT INTO order_histories...
        
        Service --> Controller : void
        Controller --> View : 204 No Content
        View --> Owner : Refresh Item Status UI
    end
end

@enduml