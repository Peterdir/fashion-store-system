@startuml
title Sequence Diagram: View Products (UC09)

autonumber
actor User
participant "Product List View\n(Thymeleaf)" as View
participant "ProductViewController\n(Controller)" as Controller
participant "ProductService\n(Service)" as Service
participant "ProductRepository\n(Repository)" as Repository
participant "RecentlyViewedService\n(Service)" as RecentlyViewedService
participant "Product\n(Entity)" as Entity
database "MySQL\n(Database)" as DB

== Load Product Category Page ==
User -> View : Access Product List page with filters
View -> Controller : category(keyword, minPrice, maxPrice, pageable)
note right: GET /category
Controller -> Service : getProducts(keyword, minPrice, maxPrice, pageable)

group Process product query
    Service -> Repository : findFiltered(keyword, minPrice, maxPrice, pageable)
    Repository -> DB : SELECT ... WHERE (filters)
    DB --> Repository : Page<Product>
    Repository --> Service : Page<Product>
end

Service -> Service : mapToDTOs(Page<Product>)

alt Products available
    Service --> Controller : Page<ProductSummaryResponseDTO>
    Controller --> View : category.html (with products)
    View --> User : Display product list
else No products found
    Service --> Controller : Empty Page
    Controller --> View : category.html (with empty message)
    View --> User : Display "No products found"
end


== View Product Detail (UC09) ==
User -> View : Click on a Product
View -> Controller : productDetail(productId, model)
note right: GET /product-detail/{id}
Controller -> Service : getProductDetail(productId)

Service -> Repository : findById(productId)
Repository -> DB : SELECT * FROM products WHERE id = productId
DB --> Repository : Product

alt Product exists
    Repository --> Service : Product
    Service -> Service : mapToDetailDTO(Product)
    Service --> Controller : ProductDetailResponseDTO

    Controller -> Service : getRelatedProducts(productId, limit)
    Service --> Controller : List<ProductSummaryResponseDTO>
    
    alt User is Logged In
        Controller -> RecentlyViewedService : trackView(email, productId)
    end

    Controller --> View : product-detail.html
    View --> User : Display Product Information
else Product not found (EF1)
    Repository --> Service : null / Optional.empty()
    Service --> Controller : throw NotFoundException
    Controller --> View : Global Exception Handler -> error.html
    View --> User : Display "Product not found" message
end

@enduml