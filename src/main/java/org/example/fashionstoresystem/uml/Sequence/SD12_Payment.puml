@startuml
title Sequence Diagram: Payment (UC12) - MoMo Integration

autonumber
actor MomoWallet as Momo
participant "PaymentController\n(Controller)" as Controller
participant "PaymentService\n(Service)" as Service
participant "MomoService\n(Service)" as MomoService
participant "OrderRepository" as OrderRepo
participant "OrderItemRepository" as ItemRepo
participant "OrderHistoryRepository" as HistoryRepo
database "MySQL" as DB

== Flow 1: MoMo IPN (Server-to-Server) ==

Momo -> Controller : POST /api/payment/momo/ipn (payload)
Controller -> Service : processMomoIPN(payload)

Service -> MomoService : verifySignature(stringParams)
MomoService --> Service : boolean (is valid)

alt Invalid Signature
    Service --> Controller : throw RuntimeException
    Controller --> Momo : 204 No Content (to stop retry)
else Valid Signature
    Service -> Service : updateOrderPayStatus(orderId, isSuccess)
    
    Service -> OrderRepo : findById(orderId)
    OrderRepo --> DB : SELECT *
    DB --> OrderRepo : orderEntity
    OrderRepo --> Service : Optional<Order>
    
    loop for each OrderItem
        Service -> ItemRepo : setStatus(PAID / PAYMENT_FAILED)
        ItemRepo -> DB : UPDATE order_items
        DB --> ItemRepo : success
        
        opt If Payment Success
            Service -> HistoryRepo : save(OrderHistory)
            HistoryRepo -> DB : INSERT INTO order_histories
        end
    end
    
    Controller --> Momo : 204 No Content
end

== Flow 2: MoMo Return (Client Redirect) ==

Momo -> Controller : GET /api/payment/momo/return?params...
Controller -> Service : processMomoReturn(allParams)

Service -> MomoService : verifySignature(allParams)
MomoService --> Service : boolean (is valid)

alt Invalid Signature
    Service --> Controller : "failed"
else Valid Signature
    Service -> Service : updateOrderPayStatus(orderId, isSuccess)
    note right: (Same logic as IPN flow to ensure status update)
    
    Service --> Controller : statusString ("success" / "failed")
end

Controller -> Momo : 302 Redirect to /personal-center?orderId=...&paymentStatus=...

@enduml