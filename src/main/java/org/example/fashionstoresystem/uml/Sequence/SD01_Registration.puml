@startuml
title Sequence Diagram: Registration (UC01)

autonumber
actor Customer
participant "AuthViewController\n(Controller)" as ViewController
participant "Register View\n(Thymeleaf / JS)" as View
participant "AuthController\n(API Controller)" as APIController
participant "AuthService\n(Service)" as Service
participant "UserRepository\n(Repository)" as Repository
participant "User\n(Entity)" as Entity
database "MySQL\n(Database)" as DB
participant "EmailService" as Mail

== Load Page ==
Customer -> ViewController : GET /register
ViewController --> Customer : register.html

== Process Registration ==
Customer -> View : Enter data (Full Name, Phone, Email, Password, Confirm Password)
Customer -> View : Click "Register"
View -> APIController : POST /api/auth/register (RegisterRequestDTO)

APIController -> Service : registerNewAccount(dto)

group Business Logic
    Service -> Service : validateRegisterInfo(dto)

    Service -> Repository : existsByEmail(email)
    Repository -> DB : SELECT ...
    DB --> Repository : result
    Repository --> Service: boolean
    
    Service -> Repository : existsByPhone(phone)
    Repository -> DB : SELECT ...
    DB --> Repository : result
    Repository --> Service: boolean

    alt Invalid / Duplicate Information
        Service --> APIController : throw RuntimeException
        APIController --> View : 400 Bad Request (Error Message)
        View --> Customer : Display error alert
    else Valid
        Service -> Service : passwordEncoder.encode(rawPassword)
        Service -> Entity: new User(..., status=PENDING)

        Service -> Service : createVerificationToken(User)

        Service -> Repository : save(User)
        Repository -> DB : INSERT INTO users ...
        DB --> Repository : user_id
        Repository --> Service : User object
        
        alt Send Email Success
            Service -> Mail : sendVerificationEmail(email, token)
            Mail --> Service : success
        else Email Fails
            Mail --> Service : Exception
            note right of Service: Catch error, modify success message
        end

        Service --> APIController : RegisterResponseDTO
        APIController --> View : 201 Created (RegisterResponseDTO)
        View --> Customer : Display success alert / redirect to login
    end
end
@enduml