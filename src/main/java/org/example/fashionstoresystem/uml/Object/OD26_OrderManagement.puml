@startuml
title Object Diagram: Order Management (UC26)\nScenario: Admin updates order status from CONFIRMED to SHIPPING

' Entity - OrderItem after status update
object "item : OrderItem" as item {
    id = 2001
    productName = "Áo Thun Trơn"
    status = "SHIPPING"
}

' Entity - History record created
object "history : OrderHistory" as history {
    id = 501
    orderItemId = 2001
    previousStatus = "CONFIRMED"
    newStatus = "SHIPPING"
    changeDate = "2026-03-19"
}

note right of item
    Order status updated:
    "CONFIRMED" -> "SHIPPING"
end note

note right of history
    OrderHistory records every
    status transition for audit trail
end note

@enduml
