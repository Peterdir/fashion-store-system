@startuml
title Object Diagram: Revenue Statistics (UC29)\nScenario: Admin views revenue report for March 2026

' DTO - Revenue report result
object "report : RevenueReportDTO" as report {
    onlineRevenue = 3350000.0
    offlineRevenue = 3500000.0
    totalOrders = 2
}

' Entity - Order 1 with items
object "order1 : Order" as o1 {
    id = 1001
    orderDate = "2026-03-05"
    totalAmount = 3350000.0
    type = "ONLINE"
}

object "item1 : OrderItem" as i1 {
    id = 1
    quantity = 1
    productName = "Áo Thun Trơn"
}

object "item2 : OrderItem" as i2 {
    id = 2
    quantity = 2
    productName = "Quần Kaki"
}

' Entity - Order 2 with items
object "order2 : Order" as o2 {
    id = 1015
    orderDate = "2026-03-12"
    totalAmount = 3500000.0
    type = "OFFLINE"
}

object "item3 : OrderItem" as i3 {
    id = 3
    quantity = 1
    productName = "Áo Khoác Da"
}

object "item4 : OrderItem" as i4 {
    id = 4
    quantity = 1
    productName = "Áo Sơ Mi"
}

' Structural relationships
report o-- o1
report o-- o2
o1 *-- i1
o1 *-- i2
o2 *-- i3
o2 *-- i4

note bottom of report
    Report period: 2026-03-01 to 2026-03-31
    Total revenue = 3350000 + 3500000
                   = 6850000 VND
end note

note bottom of o1
    order1 total = (1250000 x 2) + (850000 x 1)
                 = 3350000 VND
end note

@enduml
