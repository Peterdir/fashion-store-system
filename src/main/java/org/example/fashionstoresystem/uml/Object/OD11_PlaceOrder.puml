@startuml
title Object Diagram: Place Order (UC11)\nScenario: Customer places an order with 2 items and applies a coupon

' DTO - Data sent from checkout form
object "placeOrderRequestDto : PlaceOrderRequestDTO" as dto {
    cartItemIds = [101, 102]
    shippingAddress = "123 Nguyen Hue, Q1, HCM"
    paymentMethod = "COD"
    couponCode = "SALE50"
}

' Entity - User
object "customer : User" as user {
    id = 1
    fullName = "Nguyen Van A"
}

' Entity - Coupon applied
object "coupon : Coupon" as coupon {
    id = 10
    code = "SALE50"
    discountValue = 50000.0
    discountType = "FIXED_AMOUNT"
}

' Entity - Order created
object "order : Order" as order {
    id = 1001
    orderDate = "2026-03-19"
    totalAmount = 3300000.0
    status = "PENDING_PAYMENT"
    shippingAddress = "123 Nguyen Hue, Q1, HCM"
    paymentMethod = "COD"
    type = "ONLINE"
    hiddenByUser = false
}

' Entity - Order Items
object "item1 : OrderItem" as item1 {
    id = 201
    quantity = 2
    price = 1250000.0
    productName = "Ao Thun Trang"
    status = "PENDING_PAYMENT"
    isReviewed = false
}

object "item2 : OrderItem" as item2 {
    id = 202
    quantity = 1
    price = 850000.0
    productName = "Quan Jean Xanh"
    status = "PENDING_PAYMENT"
    isReviewed = false
}

' Entity - ProductVariants (stock updated)
object "variant1 : ProductVariant" as v1 {
    id = 5
    size = "M"
    color = "White"
    price = 1250000.0
    stockQuantity = 48
}

object "variant2 : ProductVariant" as v2 {
    id = 12
    size = "L"
    color = "Blue"
    price = 850000.0
    stockQuantity = 29
}

' Response DTO
object "response : PlaceOrderResponseDTO" as res {
    orderId = 1001
    totalAmount = 3300000.0
    status = "PENDING_PAYMENT"
    message = "Order placed successfully!"
}

' Structural relationships
order *-- item1
order *-- item2
order --> user : belongs to
order --> coupon : applies
item1 --> v1 : references
item2 --> v2 : references

note bottom of order
    Order belongs to User "Nguyen Van A"
    Coupon "SALE50" applied: -50,000d
    totalAmount = (1,250,000 x 2) + (850,000 x 1) - 50,000
                = 3,300,000 VND
end note

note bottom of v1
    Stock decreased after order:
    variant1: 50 -> 48 (qty: 2)
    variant2: 30 -> 29 (qty: 1)
end note

@enduml
