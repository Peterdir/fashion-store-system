@startuml
title Sequence Diagram - Resend Verification

actor "Khách hàng" as User

boundary "RegisterPage" as UI
control "AuthController" as C
control "AuthService" as S
entity "UserRepository" as UR
entity "VerificationTokenRepository" as TR
database "MySQL" as DB
participant "EmailService" as Mail

User -> UI : Click "Gửi lại mã"
UI -> C : resendVerification(userId)
C -> S : resendVerification(userId)

S -> UR : findById(userId)
UR -> DB : SELECT user
DB --> UR 
UR --> S

S -> TR : deleteOldToken(userId)
TR -> DB : DELETE token

S -> S : generateNewToken()

S -> TR : save(newToken)
TR -> DB : INSERT token

S -> Mail : sendVerificationEmail(newToken)

C --> UI : showResendSuccess()
UI --> User : Hiển thị gửi lại thành công

@enduml